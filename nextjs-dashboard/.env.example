# ─── Next Auth ───────────────────────────────────────────────────────────────
# openssl rand -base64 32 로 생성
AUTH_SECRET=

# ─── 소셜 로그인 ─────────────────────────────────────────────────────────────
# Google Cloud Console → API & Services → Credentials
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Naver Developers → 애플리케이션 등록
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# Kakao Developers → 내 애플리케이션
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=

# ─── 토스페이먼츠 ────────────────────────────────────────────────────────────
# https://developers.tosspayments.com/ → 개발자 도구 → API 키
NEXT_PUBLIC_TOSS_CLIENT_KEY=test_ck_...
TOSS_SECRET_KEY=test_sk_...

# ─── 데이터베이스 (Supabase) ─────────────────────────────────────────────────
# https://supabase.com/ → 프로젝트 설정 → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── AI (CMS 어드민 — 기사 초안 생성, 유사도 측정) ──────────────────────────
# https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ─── 앱 URL ──────────────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
# 프로덕션: https://um.co.kr
